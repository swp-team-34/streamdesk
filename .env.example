# Core application
DATABASE_URL=postgresql://streamdesk_user:replace_with_password@localhost:5432/streamdesk
SESSION_SECRET=replace_with_a_long_random_value
PORT=5000

# Optional platform administrator
PLATFORM_ADMIN_USERNAME=replace_with_username
PLATFORM_ADMIN_PASSWORD=replace_with_password
PLATFORM_ADMIN_NAME=replace_with_name
PLATFORM_ADMIN_EMAIL=admin@example.com

# Optional integrations
HUGGINGFACE_API_KEY=replace_with_api_key
HUGGINGFACE_MODEL=replace_with_model_name
YOUGILE_API_KEY=replace_with_api_key
YOUGILE_COMPANY_ID=replace_with_company_id
TELEGRAM_BOT_TOKEN=replace_with_bot_token
LABEL_PRINTER_HOST=192.0.2.10
LABEL_PRINTER_PORT=9100

# Optional TLS
SSL_CERT_PATH=/path/to/fullchain.pem
SSL_KEY_PATH=/path/to/privkey.pem

# Never put real secrets in this file.
