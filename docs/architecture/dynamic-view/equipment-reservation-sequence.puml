@startuml
!theme plain
skinparam backgroundColor #FEFEFE
skinparam sequenceArrowThickness 2
skinparam roundcorner 10

title Sequence Diagram: Reserve Equipment from the Warehouse

actor "Staff user" as User
participant "Equipment UI\n(React)" as UI
participant "HTTP Client" as HTTP
participant "Shared Zod schema\n(shared/schema.ts)" as Schema
participant "Express route\n(/api/equipment/reservations)" as Route
participant "Passport auth\nmiddleware" as Auth
participant "Zod request validation" as Val
participant "Equipment handlers\n(business logic)" as BL
participant "Drizzle ORM" as ORM
participant "PostgreSQL\n(equipment,\nequipment_reservations)" as DB

== Step 1 — User opens the reservation form ==

User -> UI: Open equipment item\nand click "Reserve"
UI -> Schema: Load reservation form schema\n(start date, end date, quantity)
Schema --> UI: Field definitions + validators
UI --> User: Render reservation form

== Step 2 — User submits the reservation ==

User -> UI: Fill dates & quantity,\nclick "Submit"
UI -> Schema: Validate form locally
alt Form is invalid
  Schema --> UI: Validation errors
  UI --> User: Show inline errors
else Form is valid
  UI -> HTTP: POST /api/equipment/reservations\n{ equipmentId, startDate, endDate, quantity }
end

== Step 3 — Server receives the request ==

HTTP -> Route: HTTP request + session cookie
Route -> Auth: Check session / company membership
alt Not authenticated
  Auth --> Route: Reject
  Route --> HTTP: 401 Unauthorized
  HTTP --> UI: Show "please log in"
else Authenticated
  Auth --> Route: user + company context
end

== Step 4 — Validate the request body ==

Route -> Val: Validate body against\nreservationInsertSchema
alt Invalid payload
  Val --> Route: Zod error
  Route --> HTTP: 400 Bad Request\n{ issues: [...] }
  HTTP --> UI: Show validation errors
else Valid payload
  Val --> Route: Parsed reservation data
end

== Step 5 — Apply business rules ==

Route -> BL: createReservation(userId, companyId, data)

BL -> ORM: SELECT equipment WHERE id = :equipmentId\nAND company_id = :companyId
ORM -> DB: SQL
DB --> ORM: equipment row
ORM --> BL: equipment | null

alt Equipment not found or belongs to another company
  BL --> Route: Throw NotFound / Forbidden
  Route --> HTTP: 404 / 403
else Equipment found
  BL -> ORM: SELECT overlapping reservations\nfor the same equipment & date range
  ORM -> DB: SQL
  DB --> ORM: conflicting reservations
  ORM --> BL: conflicts[]

  alt Quantity exceeds availability in the period
    BL --> Route: Throw Conflict
    Route --> HTTP: 409 Conflict\n{ reason: "not enough units available" }
    HTTP --> UI: Show "equipment not available"
  else Available
    BL -> ORM: INSERT INTO equipment_reservations
    ORM -> DB: SQL
    DB --> ORM: inserted row
    ORM --> BL: reservation
    BL --> Route: reservation
  end
end

== Step 6 — Respond to the client ==

Route --> HTTP: 201 Created\n{ reservation }
HTTP --> UI: Update local state
UI --> User: Show "Reservation created"\nand the new reservation in the list

@enduml